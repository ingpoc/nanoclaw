{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "topic",
    "summary",
    "helper_lanes",
    "recurring_pains",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "blocked", "failed"]
    },
    "topic": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "helper_lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_lane", "skeptic_lane"],
      "properties": {
        "evidence_lane": {
          "type": "string",
          "const": "explorer"
        },
        "skeptic_lane": {
          "type": "string",
          "const": "reviewer"
        }
      }
    },
    "recurring_pains": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pain_title",
          "evidence_sessions",
          "owner_surface",
          "proposal",
          "skeptic_verdict",
          "skeptic_reason"
        ],
        "properties": {
          "pain_title": {
            "type": "string"
          },
          "evidence_sessions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "owner_surface": {
            "type": "string"
          },
          "proposal": {
            "type": "string"
          },
          "skeptic_verdict": {
            "type": "string",
            "enum": ["accept", "narrow", "reject"]
          },
          "skeptic_reason": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
